{
  "devDependencies": {
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3"
  },
  "name": "capim-root",
  "private": true,
  "scripts": {
    "build": "pnpm install --frozen-lockfile && pnpm --filter capim generate",
    "deploy": "npm version --preid build prerelease --message 'New build: %s [skip ci]'",
    "lf": "pnpm --filter capim live-feedback",
    "lint": "pnpm -r lint",
    "prepare": "husky install",
    "p": "pnpm --filter capim local-client-to-remote-server-proxy",
    "s": "pnpm --filter capim start-using-https",
    "start": "pnpm --filter capim dev",
    "test": "pnpm --filter capim-test-suites test",
    "postversion": "git push --follow-tags",
    "x": "pnpm --filter capim x"
  },
  "version": "1.0.0-build.36",
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
